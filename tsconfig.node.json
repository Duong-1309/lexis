{
  "include": [
    "electron/**/*",
    "scripts/**/*",
    "src/types/**/*",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "types": ["node"],
    "paths": {}
  }
}
